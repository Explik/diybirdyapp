{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: Current File",
            "type": "debugpy",
            "request": "launch",
            "justMyCode": true,
            "redirectOutput": true,
            "program": ".venv\\Scripts\\streamlit.exe",
            "args": ["run", "${file}"],
            "console": "integratedTerminal"
        },
        {
            "type": "java",
            "name": "Spring Boot API (Dev)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.explik.diybirdyapp.DiybirdyappApplication",
            "projectName": "diybirdyapp",
            "args": "",
            "envFile": "${workspaceFolder}/.env",
            "vmArgs": "-Dspring.profiles.active=dev",
            "console": "integratedTerminal"
        },
        {
            "type": "java",
            "name": "Spring Boot API (Prod)",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "mainClass": "com.explik.diybirdyapp.DiybirdyappApplication",
            "projectName": "diybirdyapp",
            "args": "",
            "envFile": "${workspaceFolder}/.env",
            "vmArgs": "-Dspring.profiles.active=prod",
            "console": "integratedTerminal"
        }
    ]
}